{
  "name": "proconip-pypi",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "postCreateCommand": "pip install -e '.[dev,test,docs]' && pre-commit install",
  "postStartCommand": "bash .devcontainer/start-mock.sh",
  "forwardPorts": [8080, 8000],
  "portsAttributes": {
    "8080": {
      "label": "ProCon.IP Mock",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "MkDocs Preview",
      "onAutoForward": "silent"
    }
  },
  "remoteEnv": {
    "PROCONIP_MOCK_HOST": "0.0.0.0",
    "PROCONIP_MOCK_PORT": "8080",
    "PROCONIP_MOCK_DMX": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "github.vscode-github-actions"
      ],
      "settings": {
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports.ruff": "explicit"
          }
        },
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.venvFolders": [],
        "mypy-type-checker.interpreter": ["/usr/local/bin/python"],
        "mypy-type-checker.importStrategy": "fromEnvironment",
        "ruff.interpreter": ["/usr/local/bin/python"],
        "ruff.importStrategy": "fromEnvironment"
      }
    }
  }
}
